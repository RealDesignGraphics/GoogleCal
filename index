<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notion Calendar Embed</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        html, body {
            height: 100%;
            background-color: transparent; /* Seamlessly blends into Notion */
            overflow: hidden;
        }
        .calendar-container {
            width: 100%;
            height: 100vh;
            display: flex;
        }
        iframe {
            width: 100%;
            height: 100%;
            border: none;
        }
    </style>
</head>
<body>

    <!-- REPLACE YOUR_CALENDAR_ID AND YOUR_TIMEZONE BELOW -->
    <iframe src="https://calendar.google.com/calendar/embed?src=corinne%40verdantearthsolutions.com&ctz=America%2FChicago" scrolling="no"></iframe>

</body>
</html>
